{
  "mcpServers": {
    "nix": {
      "command": "nix",
      "args": [
        "run",
        "github:utensils/mcp-nixos",
        "--"
      ]
    },
    "puppeteer": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ]
    }
  },
  "context": {
    "fileName": [
      "AGENTS.md",
      "GEMINI.md"
    ]
  },
  "ui": {
    "hideBanner": true,
    "hideFooter": false,
    "hideTips": true,
    "hideWindowTitle": false,
    "showCitations": true,
    "showLineNumbers": true,
    "showMemoryUsage": false,
    "theme": "ANSI",
    "footer": {
      "hideContextPercentage": false,
      "showLabels": true,
      "items": [
        "workspace",
        "git-branch",
        "sandbox",
        "context-used",
        "quota",
        "code-changes"
      ]
    },
    "inlineThinkingMode": "full",
    "showStatusInTitle": true,
    "escapePastedAtSymbols": true,
    "hideContextSummary": true,
    "showUserIdentity": false
  },
  "ide": {
    "enabled": true,
    "hasSeenNudge": true
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "enablePermanentToolApproval": true,
    "environmentVariableRedaction": {
      "enabled": true
    },
    "enableConseca": false
  },
  "output": {
    "format": "text"
  },
  "general": {
    "vimMode": false,
    "previewFeatures": true,
    "enablePromptCompletion": true,
    "sessionRetention": {
      "warningAcknowledged": true,
      "enabled": true,
      "maxAge": "120d"
    },
    "enableNotifications": true,
    "plan": {
      "directory": "plan"
    },
    "preferredEditor": "vscode"
  },
  "hooksConfig": {
    "enabled": true
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty || true; play message",
            "name": "notify-bell-and-sound"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty || true; play complete",
            "name": "complete-bell-and-sound"
          }
        ]
      }
    ]
  },
  "tools": {
    "shell": {
      "showColor": true
    }
  },
  "experimental": {
    "modelSteering": true
  },
  "billing": {
    "overageStrategy": "ask"
  }
}
