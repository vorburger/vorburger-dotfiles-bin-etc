{
  "mcpServers": {
    "nix": {
      "command": "nix",
      "args": [
        "run",
        "github:utensils/mcp-nixos",
        "--"
      ]
    },
    "context7": {
      "httpUrl": "https://mcp.context7.com/mcp",
      "headers": {
        "Accept": "application/json, text/event-stream"
      }
    }
  },
  "context": {
    "fileName": [
      "AGENTS.md",
      "GEMINI.md"
    ]
  },
  "ui": {
    "hideBanner": true,
    "hideFooter": false,
    "hideTips": true,
    "hideWindowTitle": false,
    "showCitations": true,
    "showLineNumbers": true,
    "showMemoryUsage": false,
    "theme": "ANSI",
    "footer": {
      "hideContextPercentage": false,
      "showLabels": true,
      "items": [
        "workspace",
        "git-branch",
        "sandbox",
        "context-used",
        "quota",
        "code-changes"
      ]
    },
    "inlineThinkingMode": "full",
    "showStatusInTitle": true,
    "escapePastedAtSymbols": true,
    "hideContextSummary": true,
    "showUserIdentity": false
  },
  "ide": {
    "enabled": true,
    "hasSeenNudge": true
  },
  "security": {
    "auth": {
      "selectedType": "gemini-api-key"
    },
    "enablePermanentToolApproval": true,
    "environmentVariableRedaction": {
      "enabled": true
    },
    "enableConseca": true
  },
  "output": {
    "format": "text"
  },
  "general": {
    "vimMode": false,
    "previewFeatures": true,
    "enablePromptCompletion": true,
    "sessionRetention": {
      "warningAcknowledged": true,
      "enabled": true,
      "maxAge": "120d"
    },
    "enableNotifications": true,
    "plan": {
      "directory": "plan"
    }
  },
  "tools": {
    "shell": {
      "showColor": true
    }
  },
  "experimental": {
    "modelSteering": true
  },
  "billing": {
    "overageStrategy": "ask"
  }
}