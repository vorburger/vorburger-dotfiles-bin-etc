FROM ghcr.io/xtruder/nix-devcontainer:v1@sha256:34b3b05a767b8c16db9be933cb8a7d8772988a4bcab2567273db29c061a4bcec

COPY --chown=code:code . /var/local/vorburger-dotfiles/

# Simulate a Codespace environment so that:
# - symlink.sh backs up existing files (e.g. /root/.bashrc) instead of failing
ENV CODESPACES=true

# Accept a GitHub token to authenticate Nix flake fetches and avoid rate limits.
ARG GITHUB_TOKEN

# /etc/ssl/certs is a bind-mount in this image, so chmod changes don't persist
# across Docker RUN layers. Both the chmod and bootstrap must run in the same
# RUN step. CODESPACES is passed explicitly as 'su' may not inherit Docker ENVs.
# Enable experimental nix-command and flakes features globally so that
# home-manager activation scripts can invoke nix subcommands.
# /etc/nix/nix.conf is used here only to enable experimental features.
# When a GitHub token is provided, it is passed via NIX_CONFIG
# (extra-access-tokens = github.com=${GITHUB_TOKEN}) only for the bootstrap run,
# so no access token is written to nix.conf or persisted in the final image.
USER root
RUN chmod 755 /etc/ssl/certs \
    && mkdir -p /etc/nix \
    && printf 'experimental-features = nix-command flakes\n' >> /etc/nix/nix.conf \
    && if [ -n "${GITHUB_TOKEN}" ]; then \
           su code -c "export CODESPACES=true NIX_CONFIG='extra-access-tokens = github.com=${GITHUB_TOKEN}' && cd /var/local/vorburger-dotfiles && ./bootstrap.sh"; \
       else \
           su code -c \"export CODESPACES=true && cd /var/local/vorburger-dotfiles && ./bootstrap.sh\"; \
       fi
